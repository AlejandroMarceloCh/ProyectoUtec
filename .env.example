# Variables leídas por docker-compose. Copiá a .env y completá.
# Generar secrets con: openssl rand -hex 32

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=utec_gym

SECRET_KEY=REEMPLAZAR_CON_openssl_rand_hex_32
QR_SECRET_KEY=REEMPLAZAR_CON_openssl_rand_hex_32_DIFERENTE

# development | production
APP_ENV=development

# Whitelist de orígenes para CORS (explícita en production)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
