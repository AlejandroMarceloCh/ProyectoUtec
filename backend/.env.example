# ── Base de datos ────────────────────────────────────────────────────────────
# Dev local (host): docker-compose expone postgres en 7222
DATABASE_URL=postgresql://postgres:postgres@localhost:7222/utec_gym
# Dentro de docker compose: postgresql://postgres:postgres@db:5432/utec_gym

# ── Secretos JWT (¡obligatorios, >=32 chars!) ───────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=REEMPLAZAR_CON_openssl_rand_hex_32
QR_SECRET_KEY=REEMPLAZAR_CON_openssl_rand_hex_32_DIFERENTE

# ── TTLs ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
QR_TOKEN_EXPIRE_SECONDS=30

# ── Gym ─────────────────────────────────────────────────────────────────────
GYM_AUTO_KILL_MINUTES=120
SCHEDULER_INTERVAL_MINUTES=5
USED_TOKEN_CLEANUP_INTERVAL_MINUTES=60

# ── CORS ────────────────────────────────────────────────────────────────────
# En producción: lista explícita de dominios permitidos, SIN regex.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
# Solo se usa en development; en production se ignora por seguridad.
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$

# ── Rate limits ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_CHECKIN=60/minute
RATE_LIMIT_REFRESH=30/minute

# ── Entorno ─────────────────────────────────────────────────────────────────
# development | production — en prod el arranque falla si los secrets son inseguros
APP_ENV=development
